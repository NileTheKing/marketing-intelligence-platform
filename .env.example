# Copy this file to .env on the VM. Do not commit real secrets.

# MySQL
# Keep MYSQL_DATABASE and the database name in SPRING_DATASOURCE_URL consistent.
MYSQL_ROOT_PASSWORD=replace-with-random-root-password
MYSQL_DATABASE=axon_db
DB_USERNAME=axon_user
DB_PASSWORD=replace-with-random-app-password
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/axon_db?useSSL=false&serverTimezone=Asia/Seoul&allowPublicKeyRetrieval=true

# Redis
REDIS_PASSWORD=replace-with-random-redis-password

# App secrets
# Generate with: openssl rand -base64 32
JWT_SECRET=replace-with-random-jwt-secret
PAYMENT_TOKEN_SECRET=replace-with-random-payment-token-secret

# Optional LLM API key. Leave empty if the LLM feature is not used on this VM.
GEMINI_API_KEY=

# Internal service URLs for Docker Compose.
AXON_ENTRY_SERVICE_URL=http://entry-service:8081
AXON_CORE_SERVICE_BASE_URL=http://core-service:8080
SPRING_KAFKA_BOOTSTRAP_SERVERS=broker_1:29092
