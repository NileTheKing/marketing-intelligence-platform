# Copy these values into the shell or the VM .env only for diagnostic tracing runs.
# Do not use OTel-attached runs as the headline before/after load-test number.

OTEL_AGENT_DIR=./otel-agent
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4318

CORE_JAVA_TOOL_OPTIONS="-Xms512m -Xmx2g"
ENTRY_JAVA_TOOL_OPTIONS="-Xms256m -Xmx1536m"

OTEL_COMMON_OPTIONS="-Dotel.traces.exporter=otlp -Dotel.exporter.otlp.endpoint=${OTEL_EXPORTER_OTLP_ENDPOINT} -Dotel.exporter.otlp.protocol=http/protobuf -Dotel.metrics.exporter=none -Dotel.logs.exporter=none -Dotel.traces.sampler=always_on"

OTEL_CORE_AGENT_OPTIONS="-javaagent:/otel-agent/opentelemetry-javaagent.jar -Dotel.service.name=axon-core ${OTEL_COMMON_OPTIONS}"
OTEL_ENTRY_AGENT_OPTIONS="-javaagent:/otel-agent/opentelemetry-javaagent.jar -Dotel.service.name=axon-entry ${OTEL_COMMON_OPTIONS}"
