# Copy these values into the shell or the VM .env only for diagnostic tracing runs.
# Do not use Pinpoint-attached runs as the headline before/after load-test number.

PINPOINT_AGENT_DIR=./pinpoint-agent

# The collector host must be reachable from the Axon app containers.
# If Pinpoint runs from the official pinpoint-docker stack, attach it to the
# same Docker network or replace this with the reachable collector host.
PINPOINT_COLLECTOR_HOST=pinpoint-collector

CORE_JAVA_TOOL_OPTIONS="-Xms512m -Xmx2g"
ENTRY_JAVA_TOOL_OPTIONS="-Xms256m -Xmx1536m"

PINPOINT_CORE_AGENT_OPTIONS="-javaagent:/pinpoint-agent/pinpoint-bootstrap.jar -Dpinpoint.agentId=axon-core -Dpinpoint.applicationName=axon-core -Dprofiler.transport.grpc.collector.ip=${PINPOINT_COLLECTOR_HOST} -Dprofiler.sampling.type=PERCENT -Dprofiler.sampling.percent.sampling-rate=100"
PINPOINT_ENTRY_AGENT_OPTIONS="-javaagent:/pinpoint-agent/pinpoint-bootstrap.jar -Dpinpoint.agentId=axon-entry -Dpinpoint.applicationName=axon-entry -Dprofiler.transport.grpc.collector.ip=${PINPOINT_COLLECTOR_HOST} -Dprofiler.sampling.type=PERCENT -Dprofiler.sampling.percent.sampling-rate=100"
